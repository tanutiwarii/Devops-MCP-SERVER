# Copy to `.env` in the project root (same folder as `app.py`). It is loaded automatically on startup.
# Shell exports still win over `.env` if both are set.
#
# Blank values count as “not set”: `DEVOPS_REQUIRE_AUTH=` uses the default (auth off for local dev);
# `DEVOPS_API_KEYS=` means no keys until you paste JSON.

# --- Minimal local file (auth off, no keys) — enough to run uvicorn ---
# DEVOPS_API_KEYS=
# DEVOPS_REQUIRE_AUTH=

# --- Explicit local quickstart ---
DEVOPS_REQUIRE_AUTH=false

# --- Production-style (uncomment and use instead of the line above) ---
# When true, you must set DEVOPS_API_KEYS and/or DEVOPS_JWT_SECRET or startup will fail.
# DEVOPS_REQUIRE_AUTH=true
# JSON mapping: API key string -> role (admin | deployer | viewer). Quote the whole value for .env parsers.
# DEVOPS_API_KEYS='{"change-me-admin":"admin","change-me-deploy":"deployer","change-me-read":"viewer"}'

# Optional HS256 secret for Authorization: Bearer <jwt> (claims: sub, role, exp)
# DEVOPS_JWT_SECRET=
# DEVOPS_JWT_ALGORITHM=HS256

# Allow Prometheus to scrape /metrics without auth (internal networks only).
# DEVOPS_METRICS_NO_AUTH=false
